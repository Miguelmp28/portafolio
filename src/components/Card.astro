---
const {title, descripcion, demo, github} = Astro.props;
---

<div class="bg-white/10 backdrop-blur rounded-2xl overflow-hidden group hover:-translate-y-2 transition-transform duration-300">
    <div class="h-40 bg-black/30">
        <div class="p-6 space-y-4">
            <h3 class="text-xl font-semibold">{title}</h3>
            <p class="text-sm text-gray-300">
                {descripcion}
            </p>

            <div class="flex gap-4 pt-4">
                <a href={demo}
                    target="_blank"
                    class="px-4 py-2 rounded-lg bg-emerald-900 text-black text-sm
                        font-medium hover:bg-emerald-700 transition"   
                >
                    Demo
                </a>
                <a href={github}
                    target="_blank"
                    class="px-4 py-2 rounded-lg border border-white/20 text-sm hover:bg-white/10 transition" 
                >
                    GitHub
                </a>
            </div>
        </div>
    </div>
</div>