---
import type { GalleryItem } from "@/data/content";

interface Props {
  gallery: GalleryItem[];
}

const { gallery } = Astro.props;
---

<section id="galeria" class="bg-stone-900 py-16 sm:py-20">
  <div class="mx-auto w-[min(1120px,92vw)]">

    <h2
      data-reveal
      style="--reveal-from: translateX(-28px);"
      class="text-2xl font-bold tracking-tight text-white sm:text-3xl"
    >
      Galeria de comunidad
    </h2>
    <p
      data-reveal
      style="--reveal-from: translateY(20px); --reveal-delay: 80ms;"
      class="mt-1 text-sm text-stone-400 sm:text-base"
    >
      Momentos de fe, esperanza y vida en comunidad.
    </p>

    <div
      class="mt-6"
      data-reveal
      style="--reveal-from: translateY(28px); --reveal-delay: 160ms;"
    >
      <div class="overflow-hidden rounded-2xl">
        <div
          id="faithGallery"
          class="carousel-track flex gap-3 transition-transform duration-700 ease-out will-change-transform"
          data-carousel
        >
          {gallery.map((image) => (
            <figure class="carousel-item m-0 shrink-0 basis-[48%] overflow-hidden rounded-xl border border-stone-700 bg-stone-800 shadow-sm transition-colors duration-300 hover:border-stone-500 lg:basis-[24%]">
              <img src={image.src} alt={image.alt} loading="lazy" class="h-40 w-full object-cover" />
              <figcaption class="p-2.5 text-sm text-stone-400">{image.caption}</figcaption>
            </figure>
          ))}
        </div>
      </div>
      <div
        data-reveal
        style="--reveal-from: scale(0.8); --reveal-delay: 260ms; --reveal-dur: 500ms;"
        class="mt-4 flex items-center justify-center gap-2"
        data-carousel-dots-for="faithGallery"
        data-dots-theme="light"
      ></div>
    </div>

  </div>
</section>
