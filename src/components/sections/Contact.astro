---
interface Props {
  contact: {
    title: string;
    description: string;
    address: string;
    mapUrl: string;
  };
}

const { contact } = Astro.props;
---

<section id="contacto" class="bg-white py-16 sm:py-20">
  <div class="mx-auto w-[min(1120px,92vw)]">

    <div
      class="rounded-2xl border border-stone-200 bg-stone-50 p-6 shadow-sm sm:p-8"
      data-reveal
      style="--reveal-from: translateY(32px) scale(0.98);"
    >
      <h2
        data-reveal
        style="--reveal-from: translateX(-24px); --reveal-delay: 80ms;"
        class="text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl"
      >
        {contact.title}
      </h2>

      <p
        data-reveal
        style="--reveal-from: translateY(18px); --reveal-delay: 160ms;"
        class="mt-2 text-sm text-stone-600 sm:text-base"
      >
        {contact.description}
      </p>

      <p
        data-reveal
        style="--reveal-from: translateY(18px); --reveal-delay: 220ms;"
        class="mt-3 text-sm font-semibold text-stone-800 sm:text-base"
      >
        {contact.address}
      </p>

      <div
        data-reveal
        style="--reveal-from: translateY(16px) scale(0.95); --reveal-delay: 300ms; --reveal-dur: 550ms;"
      >
        <a
          href={contact.mapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex rounded-full border border-stone-300 bg-stone-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-rose-600"
        >
          Ver en Google Maps
        </a>
      </div>
    </div>

  </div>
</section>
