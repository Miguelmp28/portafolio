---
import type { EventItem } from "@/data/content";

interface Props {
  events: EventItem[];
}

const { events } = Astro.props;
---

<section id="agenda" class="bg-amber-50 py-16 sm:py-20">
  <div class="mx-auto w-[min(1120px,92vw)]">

    <h2
      data-reveal
      style="--reveal-from: translateX(-28px);"
      class="text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl"
    >
      Agenda de la semana
    </h2>
    <p
      data-reveal
      style="--reveal-from: translateY(20px); --reveal-delay: 80ms;"
      class="mt-1 text-sm text-stone-600 sm:text-base"
    >
      Ven y participa en nuestros eventos
    </p>

    <div
      class="mt-6"
      data-reveal
      style="--reveal-from: translateY(28px); --reveal-delay: 160ms;"
    >
      <div class="overflow-hidden rounded-2xl">
        <div
          id="agendaTrack"
          class="carousel-track flex gap-3 transition-transform duration-700 ease-out will-change-transform"
          data-carousel
        >
          {events.map((event) => (
            <article
              class="agenda-card carousel-item shrink-0 basis-[48%] rounded-xl border border-amber-200 bg-white p-3 shadow-sm transition-all duration-300 hover:border-amber-300 hover:shadow-md lg:basis-[32%]"
              data-service-day={event.day}
            >
              <small class="text-xs font-semibold text-amber-700">{event.day}</small>
              <h3 class="mt-1 text-lg font-bold text-stone-900">{event.title}</h3>
              <p class="mt-1.5 text-sm text-stone-600">{event.time}</p>
              <p class="text-sm text-stone-500">{event.place}</p>
            </article>
          ))}
        </div>
      </div>
      <div
        data-reveal
        style="--reveal-from: scale(0.8); --reveal-delay: 260ms; --reveal-dur: 500ms;"
        class="mt-3 flex items-center justify-center gap-2"
        data-carousel-dots-for="agendaTrack"
      ></div>
    </div>

  </div>
</section>
