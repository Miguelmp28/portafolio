---
const { label } = Astro.props;
---

<div class='flex flex-col items-center gap-3 group cursor-default py-1.5'>
    <div class='w-10 h-10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300'>
        <slot />
    </div>
    <span class='text-sm text-gray-300 group-hover:text-white'>
        {label}
    </span>
</div>