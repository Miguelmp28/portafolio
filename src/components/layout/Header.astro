---
import type { NavLink } from "@/data/content";

interface Props {
  brand: { main: string; highlight: string };
  links: NavLink[];
}

const { brand, links } = Astro.props;

function iconFor(label: string) {
  const n = label.toLowerCase();
  if (n.includes("inicio"))      return "home";
  if (n.includes("agenda"))      return "calendar";
  if (n.includes("galeria"))     return "gallery";
  if (n.includes("ministerios")) return "group";
  return "pin";
}
---

<header id="siteHeader" class="fixed inset-x-0 top-0 z-40">
  <div data-header-inner class="border-b">
    <div class="mx-auto flex w-[min(1120px,92vw)] items-center justify-between gap-3 px-3 py-1.5 sm:px-4">
      <a href="#inicio" class="flex items-center gap-2">
        <img
          src="/assests/logo.webp"
          alt={`${brand.main} ${brand.highlight}`}
          class="h-15 w-10 object-contain saturate-150 contrast-110 sm:h-10"
        />
      </a>

      <nav class="hidden items-center gap-2 md:flex" aria-label="Navegacion principal">
        {links.map((link) => (
          <a
            href={link.href}
            class="rounded-full px-3 py-1.5 text-sm font-semibold text-stone-600 transition-all duration-300 hover:bg-rose-100 hover:text-rose-700"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <button
        id="menuBtn"
        class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-stone-700 shadow-sm transition-all duration-300 hover:bg-rose-100 hover:text-rose-700 md:hidden"
        type="button"
        aria-label="Abrir menu"
        aria-controls="sidebarMenu"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M4 7h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div id="menuOverlay" class="fixed inset-0 z-50 bg-stone-900/45 backdrop-blur-[2px]" hidden></div>

<aside
  id="sidebarMenu"
  class="fixed right-0 top-0 z-[55] flex h-screen w-[min(86vw,360px)] translate-x-full flex-col bg-stone-50 px-4 py-4 shadow-2xl transition-transform duration-500"
  aria-hidden="true"
>
  <div class="mb-5 rounded-2xl border border-stone-200 bg-gradient-to-br from-rose-50 via-white to-stone-50 p-4 shadow-sm">
    <div class="mb-3 flex items-start justify-between gap-3">
      <div class="rounded-xl border border-stone-200 bg-white p-1.5 shadow-sm">
        <img
          src="/assests/logo.webp"
          alt={`${brand.main} ${brand.highlight}`}
          class="h-11 w-auto object-contain saturate-150 contrast-110"
        />
      </div>
      <button
        id="closeSidebar"
        class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-stone-300 bg-white text-stone-700 transition-colors duration-300 hover:bg-stone-100"
        type="button"
        aria-label="Cerrar menu"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
          <path d="M6 6l12 12"></path>
          <path d="M18 6L6 18"></path>
        </svg>
      </button>
    </div>
    <p class="text-xs font-medium text-stone-500">Explora la comunidad y los espacios de fe.</p>
  </div>

  <nav class="flex flex-1 flex-col gap-2" aria-label="Navegacion movil">
    {links.map((link) => {
      const icon = iconFor(link.label);
      return (
        <a
          href={link.href}
          class="sidebar-link group flex items-center gap-3 rounded-xl border border-stone-200 bg-white px-3 py-3 text-stone-700 shadow-sm transition-all duration-300 hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-stone-200 bg-stone-50 text-stone-600 transition-colors duration-300 group-hover:border-rose-200 group-hover:bg-rose-50 group-hover:text-rose-700">
            {icon === "home" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
            )}
            {icon === "calendar" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            )}
            {icon === "gallery" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            )}
            {icon === "group" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            )}
            {icon === "pin" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-5.68 7-11a7 7 0 1 0-14 0c0 5.32 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
            )}
          </span>
          <span class="text-sm font-semibold">{link.label}</span>
          <span class="ml-auto text-stone-300 transition-colors duration-300 group-hover:text-stone-500">{">"}</span>
        </a>
      );
    })}
  </nav>
</aside>

<button
  id="scrollTopBtn"
  type="button"
  class="fixed bottom-16 right-4 z-[45] hidden h-10 w-10 items-center justify-center rounded-full bg-stone-900 text-white shadow-lg transition-all duration-300 hover:bg-rose-600 sm:bottom-[4.5rem] sm:right-5"
  aria-label="Subir al inicio"
>
  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="m18 15-6-6-6 6"></path>
  </svg>
</button>
