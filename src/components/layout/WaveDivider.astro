---
interface Props {
  fromBg: string;
  toFill: string;
  flip?: boolean;
}

const { fromBg, toFill, flip = false } = Astro.props;

// Top-fill path: covers Y=0 → wave curve → back to Y=0
// The rect below fills the whole SVG with toFill first,
// then this path paints fromBg on top — no bottom gap possible.
const topPath = flip
  ? "M0,0 L0,62 C180,22 360,100 540,56 C720,12 900,88 1080,50 C1260,12 1380,68 1440,46 L1440,0 Z"
  : "M0,0 L0,62 C180,100 360,22 540,66 C720,110 900,32 1080,70 C1260,108 1380,52 1440,74 L1440,0 Z";
---

<div
  class="w-full overflow-hidden leading-[0] -mb-px"
  style={`background-color: ${fromBg};`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1440 100"
    preserveAspectRatio="none"
    class="block h-16 w-full sm:h-24 lg:h-32"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Fill entire SVG with destination color — eliminates any bottom gap -->
    <rect width="1440" height="100" fill={toFill} />
    <!-- Draw the source color on top to create the wave shape -->
    <path d={topPath} fill={fromBg} />
  </svg>
</div>
