---
interface Props {
  fromBg: string;
  toFill: string;
  flip?: boolean;
}

const { fromBg, toFill, flip = false } = Astro.props;


const frontPath = flip
  ? "M0,60 C180,20 360,100 540,55 C720,10 900,90 1080,50 C1260,10 1380,70 1440,45 L1440,120 L0,120 Z"
  : "M0,60 C180,100 360,20 540,65 C720,110 900,30 1080,70 C1260,110 1380,50 1440,75 L1440,120 L0,120 Z";

const backPath = flip
  ? "M0,80 C200,50 400,110 600,70 C800,30 1000,100 1200,65 C1320,45 1400,80 1440,72 L1440,120 L0,120 Z"
  : "M0,80 C200,110 400,50 600,90 C800,130 1000,60 1200,95 C1320,115 1400,80 1440,88 L1440,120 L0,120 Z";
---

<div
  class="w-full overflow-hidden leading-[0]"
  style={`background-color: ${fromBg};`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1440 100"
    preserveAspectRatio="none"
    class="block h-16 w-full sm:h-24 lg:h-32"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d={frontPath} fill={toFill} fill-opacity="1" />
  </svg>
</div>
