---
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro';
import GmailIcon from '@/components/icons/GmailIcon.astro';
import '@/styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portafolio</title>
    <script src="https://code.iconify.design/iconify-icon/1.0.8/iconify-icon.min.js"></script>
    <script src="https://code.iconify.design/3/3.1.1/iconify.min.js"></script>
</head>
<body class="bg-emerald-500 text-white">
    <Header />
    <main>
        <slot />
    </main>
    <Footer />
    <div class="fixed bottom-6 right-6 z-50 grid grid-cols-2 gap-4">
        <button
            id="scrollTop"
            aria-label="subir"
            class="w-10 h-10 md:w-10 md:h-10 rounded-full bg-black/90
                flex items-center justify-center text-white shadow-xl
                hover:scale-110 transition-all duration-300 cursor-pointer"
        >
            <span class="iconify text-xl" data-icon="mdi:arrow-up"></span>
        </button>
        <a
            href="mailto:miguelmedrano.dev@gmail.com"
            aria-label="Contactar"
            class="w-10 h-10 md:w-10 md:h-10
                rounded-full bg-black/90
                flex items-center justify-center
                text-white
                shadow-xl
                hover:scale-110 transition-all"
        >
            <GmailIcon class="w-6 h-6" />
        </a>
    </div>
</body>
<script>
    const btn = document.getElementById('scrollTop');

    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
            btn.classList.remove('opacity-0', 'pointer-events-none');
        } else {
            btn.classList.add('opacity-0', 'pointer-events-none');
        }
    });

    btn.addEventListener('click', () => {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
</script>
</html>