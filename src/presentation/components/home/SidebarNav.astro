---
import type { NavLink } from "@/domain/home/content";

interface Props {
  brand: {
    main: string;
    highlight: string;
  };
  links: NavLink[];
}

const { brand, links } = Astro.props;

function iconFor(label: string) {
  const normalized = label.toLowerCase();
  if (normalized.includes("inicio")) return "home";
  if (normalized.includes("agenda")) return "calendar";
  if (normalized.includes("galeria")) return "gallery";
  if (normalized.includes("ministerios")) return "group";
  return "pin";
}
---

<header class="fixed inset-x-0 top-0 z-40">
  <div class="border-b border-zinc-200 bg-white/90 backdrop-blur-md dark:border-zinc-700 dark:bg-zinc-900/90">
    <div class="mx-auto flex w-[min(1120px,92vw)] items-center justify-between gap-3 px-3 py-1.5 sm:px-4">
      <img
        src="/assests/logo.webp"
        alt={`${brand.main} ${brand.highlight}`}
        class="h-15 w-10 object-contain saturate-150 contrast-110 sm:h-10"
      />

      <nav class="hidden items-center gap-2 md:flex" aria-label="Navegacion principal">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="rounded-full px-3 py-1.5 text-sm font-semibold text-zinc-600 transition-all duration-500 hover:bg-rose-100 hover:text-rose-700 dark:text-zinc-400 dark:hover:bg-rose-950/40 dark:hover:text-rose-400"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <!-- Dark mode toggle -->
        <button
          id="darkModeBtn"
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 bg-white text-zinc-600 shadow-sm transition-all duration-500 hover:bg-zinc-100 hover:text-zinc-900 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-700 dark:hover:text-zinc-100"
          aria-label="Cambiar modo oscuro"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="darkModeSunIcon" viewBox="0 0 24 24" class="hidden h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="darkModeMoonIcon" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>

        <button
          id="menuBtn"
          class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-zinc-700 shadow-sm transition-all duration-500 hover:bg-rose-100 hover:text-rose-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-rose-950/40 dark:hover:text-rose-400 md:hidden"
          type="button"
          aria-label="Abrir menu"
          aria-controls="sidebarMenu"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <path d="M4 7h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 17h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<div id="menuOverlay" class="fixed inset-0 z-50 bg-zinc-900/45 backdrop-blur-[2px]" hidden></div>
<aside
  id="sidebarMenu"
  class="fixed right-0 top-0 z-[55] flex h-screen w-[min(86vw,360px)] translate-x-full flex-col bg-zinc-50 px-4 py-4 shadow-2xl transition-transform duration-500 dark:bg-zinc-950"
  aria-hidden="true"
>
  <div class="mb-5 rounded-2xl border border-zinc-200 bg-gradient-to-br from-rose-50 via-white to-zinc-50 p-4 shadow-sm dark:border-zinc-700 dark:from-rose-950/20 dark:via-zinc-900 dark:to-zinc-950">
    <div class="mb-3 flex items-start justify-between gap-3">
      <div class="rounded-xl border border-zinc-200 bg-white p-1.5 shadow-sm dark:border-zinc-700 dark:bg-zinc-800">
        <img
          src="/assests/logo.webp"
          alt={`${brand.main} ${brand.highlight}`}
          class="h-11 w-auto object-contain saturate-150 contrast-110"
        />
      </div>
      <button
        id="closeSidebar"
        class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-zinc-300 bg-white text-zinc-700 transition-colors duration-500 hover:bg-zinc-100 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
        type="button"
        aria-label="Cerrar menu"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
          <path d="M6 6l12 12"></path>
          <path d="M18 6L6 18"></path>
        </svg>
      </button>
    </div>
    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-500">Explora la comunidad y los espacios de fe.</p>
  </div>

  <nav class="flex flex-1 flex-col gap-2" aria-label="Navegacion movil">
    {
      links.map((link) => {
        const icon = iconFor(link.label);
        return (
          <a
            href={link.href}
            class="sidebar-link group flex items-center gap-3 rounded-xl border border-zinc-200 bg-white px-3 py-3 text-zinc-700 shadow-sm transition-all duration-500 hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-rose-800 dark:hover:bg-rose-950/30 dark:hover:text-rose-400"
          >
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-200 bg-zinc-50 text-zinc-600 transition-colors duration-500 group-hover:border-rose-200 group-hover:bg-rose-50 group-hover:text-rose-700 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400 dark:group-hover:border-rose-800 dark:group-hover:bg-rose-950/40 dark:group-hover:text-rose-400">
              {icon === "home" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
              )}
              {icon === "calendar" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              )}
              {icon === "gallery" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              )}
              {icon === "group" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
              {icon === "pin" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-5.68 7-11a7 7 0 1 0-14 0c0 5.32 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              )}
            </span>
            <span class="text-sm font-semibold">{link.label}</span>
            <span class="ml-auto text-zinc-300 transition-colors duration-500 group-hover:text-zinc-500 dark:text-zinc-600 dark:group-hover:text-zinc-400">{">"}</span>
          </a>
        );
      })
    }
  </nav>
</aside>

<button
  id="scrollTopBtn"
  type="button"
  class="fixed bottom-4 right-28 z-[45] hidden h-10 w-10 items-center justify-center rounded-full bg-zinc-900 text-white shadow-lg transition-all duration-500 hover:bg-rose-600 dark:bg-zinc-700 dark:hover:bg-rose-600 sm:bottom-5 sm:right-30"
  aria-label="Subir al inicio"
>
  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="m18 15-6-6-6 6"></path>
  </svg>
</button>
