---
import type { NavLink } from "@/domain/home/content";

interface Props {
  brand: {
    main: string;
    highlight: string;
  };
  links: NavLink[];
}

const { brand, links } = Astro.props;

function iconFor(label: string) {
  const normalized = label.toLowerCase();
  if (normalized.includes("inicio")) return "home";
  if (normalized.includes("agenda")) return "calendar";
  if (normalized.includes("galeria")) return "gallery";
  if (normalized.includes("ministerios")) return "group";
  return "pin";
}
---

<header class="sticky top-4 z-40 mx-auto mt-4 w-[min(1120px,92vw)]">
  <div class="flex items-center justify-between gap-4 rounded-full border border-zinc-300/80 bg-white/95 px-4 py-3 shadow-sm backdrop-blur">
    <a href="#inicio" class="text-sm font-extrabold tracking-[0.04em] text-zinc-900 transition-colors duration-300 hover:text-zinc-700 sm:text-base">
      {brand.main} <span class="text-amber-700">{brand.highlight}</span>
    </a>

    <nav class="hidden flex-wrap gap-4 md:flex" aria-label="Navegacion principal">
      {
        links.map((link) => (
          <a href={link.href} class="text-sm text-zinc-600 transition-colors duration-300 hover:text-zinc-900">{link.label}</a>
        ))
      }
    </nav>

    <button
      id="menuBtn"
      class="inline-flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-xl border border-zinc-300 text-zinc-800 transition-colors duration-300 hover:bg-zinc-100 md:hidden"
      type="button"
      aria-label="Abrir menu"
      aria-controls="sidebarMenu"
      aria-expanded="false"
    >
      <span class="h-0.5 w-5 bg-current"></span>
      <span class="h-0.5 w-5 bg-current"></span>
      <span class="h-0.5 w-5 bg-current"></span>
    </button>
  </div>
</header>

<div id="menuOverlay" class="fixed inset-0 z-50 bg-zinc-900/30" hidden></div>
<aside
  id="sidebarMenu"
  class="fixed right-0 top-0 z-[55] flex h-screen w-[min(84vw,340px)] translate-x-full flex-col border-l border-zinc-300 bg-white px-4 py-4 shadow-2xl transition-transform duration-200"
  aria-hidden="true"
>
  <div class="mb-6 rounded-2xl border border-zinc-200 bg-zinc-50 p-4">
    <div class="mb-3 flex items-center justify-between">
      <p class="text-sm font-bold tracking-wide text-zinc-900">
        {brand.main} <span class="text-amber-700">{brand.highlight}</span>
      </p>
      <button
        id="closeSidebar"
        class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-zinc-300 text-lg text-zinc-900 transition-colors duration-300 hover:bg-zinc-100"
        type="button"
        aria-label="Cerrar menu"
      >
        x
      </button>
    </div>
    <p class="text-xs text-zinc-500">Explora la comunidad y los espacios de fe.</p>
  </div>

  <nav class="flex flex-col gap-2" aria-label="Navegacion movil">
    {
      links.map((link) => {
        const icon = iconFor(link.label);
        return (
          <a
            href={link.href}
            class="sidebar-link group flex items-center gap-3 rounded-xl border border-zinc-200 px-3 py-3 text-zinc-700 transition-colors duration-300 hover:border-zinc-300 hover:bg-zinc-50 hover:text-zinc-900"
          >
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white border border-zinc-200 text-zinc-600 group-hover:bg-amber-50 group-hover:text-amber-700 group-hover:border-amber-200 transition-colors duration-300">
              {icon === "home" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
              )}
              {icon === "calendar" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              )}
              {icon === "gallery" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              )}
              {icon === "group" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
              {icon === "pin" && (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-5.68 7-11a7 7 0 1 0-14 0c0 5.32 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              )}
            </span>
            <span class="text-sm font-medium">{link.label}</span>
          </a>
        );
      })
    }
  </nav>
</aside>
