---
interface Props {
  radio: {
    title: string;
    description: string;
    embedUrl: string;
  };
}

const { radio } = Astro.props;
const hasEmbed = Boolean(radio.embedUrl?.trim());
---

<div class="fixed bottom-4 right-4 z-[60] sm:bottom-5 sm:right-5">
  <button
    id="radioPlayStopBtn"
    type="button"
    class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-green-600/30 transition-colors duration-500 hover:bg-green-700 disabled:cursor-not-allowed disabled:opacity-60"
    aria-label="Control de emisora"
    data-playing="false"
    disabled={!hasEmbed}
  >
    {
      hasEmbed ? (
        <>
          <svg id="radioPlayIcon" aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
            <path d="M8 5v14l11-7z"></path>
          </svg>
          <svg
            id="radioStopIcon"
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="hidden h-4 w-4 fill-current"
          >
            <rect x="7" y="7" width="10" height="10" rx="1.5"></rect>
          </svg>
          <span id="radioPlayStopLabel">Play</span>
        </>
      ) : (
        <span>Sin señal</span>
      )
    }
  </button>
</div>

{
  hasEmbed && (
    <iframe
      id="radioStreamFrame"
      title={radio.title}
      data-src={radio.embedUrl}
      src="about:blank"
      class="hidden"
      allow="autoplay; encrypted-media"
    ></iframe>
  )
}
