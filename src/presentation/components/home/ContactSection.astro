---
interface Props {
  contact: {
    title: string;
    description: string;
    address: string;
    mapUrl: string;
  };
}

const { contact } = Astro.props;
---

<section id="contacto" class="mx-auto w-[min(1120px,92vw)]">
  <div class="rounded-xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-900 sm:p-5">
    <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-3xl">{contact.title}</h2>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 sm:text-base">{contact.description}</p>
    <p class="mt-3 text-sm font-semibold text-zinc-800 dark:text-zinc-200 sm:text-base">{contact.address}</p>
    <a
      href={contact.mapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 inline-flex rounded-full border border-zinc-300 bg-zinc-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors duration-500 hover:bg-zinc-800 dark:border-zinc-600 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-white"
    >
      Ver en Google Maps
    </a>
  </div>
</section>
