---
interface Props {
  contact: {
    title: string;
    description: string;
    address: string;
    mapUrl: string;
  };
}

const { contact } = Astro.props;
---

<section id="contacto" class="mx-auto w-[min(1120px,92vw)]">
  <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
    <h2 class="text-3xl font-bold tracking-tight text-zinc-900">{contact.title}</h2>
    <p class="mt-2 text-zinc-600">{contact.description}</p>
    <p class="mt-3 font-semibold text-zinc-800">{contact.address}</p>
    <a
      href={contact.mapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-flex rounded-full border border-zinc-300 bg-zinc-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-zinc-800"
    >
      Ver en Google Maps
    </a>
  </div>
</section>
