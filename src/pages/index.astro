---
import { siteContent } from "@/data/content";
import HeaderReact   from "@/components/layout/Header";
import Footer        from "@/components/layout/Footer.astro";
import RadioPlayer   from "@/components/layout/RadioPlayer.astro";
import WaveDivider   from "@/components/layout/WaveDivider.astro";
import HeroReact        from "@/components/sections/Hero";
import SceneTransition  from "@/components/sections/SceneTransition";
import About            from "@/components/sections/About";
import Ministries    from "@/components/sections/Ministries";
import Schedule      from "@/components/sections/Schedule";
import Gallery       from "@/components/sections/Gallery";
import Contact       from "@/components/sections/Contact";
import "@/styles/global.css";

const data = siteContent;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Iglesia Cristiana Amor</title>
    <link rel="icon" type="image/webp" href="/assests/logo.webp" />
    <meta name="description" content="Comunidad de fe para crecer, servir y caminar juntos en Cristo." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Anton&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen bg-stone-50 text-stone-900" style="font-family: 'Outfit', sans-serif;">

    <!-- Fondo sutil -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-[1] bg-[linear-gradient(to_bottom,rgba(250,250,249,0.12),rgba(245,245,244,0.56)_42%),repeating-linear-gradient(to_right,rgba(120,113,108,0.03)_0_1px,transparent_1px_72px)]"
    ></div>

    <div class="relative z-[2] overflow-x-hidden">
      <!-- Header con React: scroll, mobile menu, scroll-to-top -->
      <HeaderReact brand={data.brand} links={data.navLinks} client:load />

      <main>
        <!-- 1. Hero -->
        <HeroReact hero={data.hero} client:load />

        <!-- Transición cinematográfica: tarjeta que encoge (efecto lenis.dev) -->
        <SceneTransition client:load />

        <!-- 2. Quiénes somos -->
        <About about={data.about} client:visible />

        <!-- 3. Ministerios -->
        <Ministries ministries={data.ministries} client:visible />

        <!-- 3. Agenda -->
        <Schedule events={data.events} client:visible />

        <!-- white → stone-900 -->
        <WaveDivider fromBg="#ffffff" toFill="#0c0a09" flip />

        <!-- 4. Galería -->
        <Gallery gallery={data.gallery} client:visible />

        <!-- 5. Contacto -->
        <Contact contact={data.contact} client:visible />
      </main>

      <Footer />
    </div>

    <RadioPlayer radio={data.radio} />

    <!-- Partículas animadas en el fondo -->
    <script defer src="/scripts/faith-bg.js"></script>

    <!-- Lenis smooth scroll + GSAP ScrollTrigger sync -->
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 1.8,
      });

      lenis.on("scroll", ScrollTrigger.update);
<<<<<<< HEAD
